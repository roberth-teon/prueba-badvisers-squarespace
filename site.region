<!doctype html>
<html class="touch-styles {.if authenticatedAccount}authenticated-account{.end}">
  <head>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    {.if template.mobileStylesEnabled}<meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no">{.end}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    {squarespace-headers}
    <script>(function(){var touchTest="ontouchstart"in window||navigator.msMaxTouchPoints;if(!touchTest){with(document.documentElement){className=className.replace(new RegExp("touch-styles"),"")}}})()</script>
  </head>
  {.if template.mobileStylesEnabled}<!-- Mobile Styles Enabled -->{.or}<!-- Mobile Styles Disabled -->{.end}
  <body id="{squarespace.page-id}" class="{squarespace.page-classes}{.if website.logoImageUrl} has-logo-image{.or} has-site-title{.end}{.if website.siteTagLine} has-tagline{.end}{.if showCart} has-cart{.end}{.if websiteSettings.userAccountsSettings.loginAllowed} has-user-accounts{.end}{.if website.socialAccounts.0} has-social{.end}<squarespace:navigation navigationId="mainNav">{.if items.0} has-primary-nav{.end}</squarespace:navigation><squarespace:navigation navigationId="secondaryNav">{.if items.0} has-secondary-nav{.end}</squarespace:navigation>{.section collection}{.background-source-video?} has-video-background-banner{.end}{.end}" data-controller="BodyClassController">

  <div class="overflow-wrapper">

    {# <!-- include responsive navigation --> }
    {@|apply responsive-nav.block}

    <div id="site" class="site-container">

      {# <!-- include ancillary header layout --> }
      {@|apply header.block}

      <div id="content" class="content-container">

        {# <!-- custom project / gallery banner else page banner, but never on the homepage: the hero lives inside the page's own content block --> }
        {.section collection}{.if homepage}
        {.or}
          {.equal? collection.typeName "project"}
            {@|apply project-banner.block}
          {.or}
            {.equal? collection.typeName "gallery"}
              {@|apply project-banner.block}
            {.or}
              {@|apply page-banner.block}
            {.end}
          {.end}
        {.end}{.end}

        <main id="page" class="site-page" role="main"{.equal? collection.typeName "project"} data-controller="ProjectController"{.end}>

          {.equal? collection.typeName "page"}{.or}
          {# <!-- when not a page, include collection specific header via open block field --> }
          <squarespace:block-field class="collection-header" id="collection-header-{collection.id}" columns="12" label={localizedStrings.collectionHeaderContent} />
          {.end}

          <div class="main-content" data-content-field="main-content">
            {# <!-- render page main content --> }
            {squarespace.main-content}
          </div>

          {.equal? collection.typeName "page"}{.or}
          {# <!-- when not a page, include collection specific footer via open block field --> }
          <squarespace:block-field class="collection-footer" id="collection-footer-{collection.id}" columns="12" label={localizedStrings.collectionFooterContent} />
          {.end}

          <squarespace:folder-navigation template="index-navigation" />

        </main>

        <footer id="contacto" class="badv-site-footer" role="contentinfo">
          <div class="badv-footer-main container">
            <div class="badv-footer-brand">
              <a href="/" class="badv-footer-brand__link" aria-label="{siteTitle} — Inicio">
                {.section website}
                  {.section logoImageUrl}
                    {.ctx @image src=logoImageUrl alt=siteTitle}
                    {@image|apply/apply-image-component.block/
                      /class=badv-footer-brand__logo/
                      /sizes=320px/
                      /elementTiming=df-footer-logo/
                    }
                  {.or}
                    <span class="badv-side-nav__logo-text">{siteTitle}</span>
                  {.end}
                {.end}
              </a>
            </div>
            <div class="badv-footer-columns">
              <div class="badv-footer-col">
                <h3 class="badv-footer-col__title">Menú</h3>
                <ul class="badv-footer-nav">
                  <li><a href="/">Inicio</a></li>
                  <li><a href="/capacidades">Capacidades</a></li>
                  <li><a href="/sectores">Sectores</a></li>
                  <li><a href="/#casos-de-exito">Transacciones</a></li>
                  <li><a href="/equipo">Expertise</a></li>
                  <li><a href="/publicaciones">Publicaciones</a></li>
                  <li><a href="/#contacto">Contacto</a></li>
                </ul>
              </div>
              <div class="badv-footer-col">
                <h3 class="badv-footer-col__title">Capacidades</h3>
                <ul class="badv-footer-list">
                  <li><a href="/capacidades#levantamiento-de-capital">Levantamiento de Capital</a></li>
                  <li><a href="/capacidades#estructuracion-vehiculos">Estructuración de Vehículos de Inversión</a></li>
                  <li><a href="/capacidades#banca-de-inversion">Banca de Inversión</a></li>
                  <li><a href="/capacidades#finanzas-corporativas">Finanzas Corporativas</a></li>
                  <li><a href="/capacidades#project-finance">Project Finance</a></li>
                </ul>
              </div>
              <div class="badv-footer-col">
                <h3 class="badv-footer-col__title">Publicaciones</h3>
                <ul class="badv-footer-nav">
                  <li><a href="/publicaciones">Publicaciones</a></li>
                  <li><a href="mailto:info@b-advisers.com?subject=Suscripci%C3%B3n%20a%20insights">Suscríbase</a></li>
                </ul>
              </div>
              <div class="badv-footer-col badv-footer-col--contact">
                <h3 class="badv-footer-col__title">Contacto</h3>
                <div class="badv-footer-contact">
                  <a href="mailto:info@b-advisers.com" class="badv-footer-contact-btn badv-footer-contact-btn--email">
                    <span class="badv-footer-contact-btn__value">info@b-advisers.com</span>
                  </a>
                  <a href="https://www.linkedin.com/company/b-advisers-capital-solutions" class="badv-footer-contact-btn badv-footer-contact-btn--linkedin" target="_blank" rel="noopener noreferrer">
                    <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.127 0 2.063 2.063 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                    LinkedIn
                  </a>
                </div>
              </div>
            </div>
          </div>
          <div class="badv-footer-legal container">
            Business Advisers Capital Solutions LLC actúa exclusivamente en calidad de asesor financiero. En ningún caso se considerará como entidad financiera, institución crediticia, prestamista o fiduciario. Todas las decisiones relacionadas con operaciones de crédito, financiamiento o inversión son adoptadas de manera independiente y bajo exclusiva responsabilidad de las instituciones financieras y/o de los clientes, sin que exista obligación, garantía o compromiso alguno por parte de la compañía.
          </div>
        </footer>

      </div>
    </div>


    <squarespace:script src="site-bundle.js" combo="false" />
    <squarespace:script src="custom.js" combo="false" />

    {squarespace-footers}


  </body>
</html>
